{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "functions": {
    "api/index.py": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/pipeline/jobs/drain", "schedule": "* * * * *" },
    { "path": "/api/pipeline/cron/cleanup", "schedule": "0 3 * * *" }
  ]
}
