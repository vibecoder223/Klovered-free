# Klovered Free — environment variables.
#
# Copy to `.env.local` for local dev, and set the SAME keys in the Vercel
# project (Settings → Environment Variables → Production + Preview). Missing
# Supabase keys are the usual cause of a 500 on /api/session in production:
# the server Supabase client throws when they're absent.
#
# Import your local .env.local into Vercel in one step (after `vercel login`):
#   node scripts/vercel-env-import.mjs

# ── Supabase (REQUIRED) ───────────────────────────────────────────────
# Public — inlined into the browser bundle at build time.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-only — bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# Optional: direct Postgres URL (migrations/tooling only; not read at runtime).
SUPABASE_DB_URL=

# ── AI: Mistral (REQUIRED for the pipeline) ───────────────────────────
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_API_KEY=your_mistral_key
LLM_MODEL=mistral-large-latest
LLM_MODEL_FAST=mistral-small-2603
# mistral-embed key (usually the same account key).
MISTRAL_API_KEY=your_mistral_key
# Independent grounding re-scorer. "1" = on (recommended), "" = heuristic only.
RAG_USE_CONFIDENCE_LLM=1

# ── Per-model rate gate (safe defaults; override only to match your tier) ──
LLM_RPM=15
LLM_TPM=400000
LLM_MAX_CONCURRENCY=8
LLM_MIN_INTERVAL_MS=0
LLM_RPM_FAST=100
LLM_TPM_FAST=100000
LLM_MAX_CONCURRENCY_FAST=12
LLM_MIN_INTERVAL_MS_FAST=150

# ── Cron (REQUIRED for 48h cleanup) ───────────────────────────────────
# Shared secret. Vercel Cron sends it as `Authorization: Bearer $CRON_SECRET`
# to GET /api/cron/cleanup on the schedule in vercel.json.
CRON_SECRET=generate_a_long_random_string

# ── Contact form (optional — the "Talk to us" flow) ───────────────────
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# ── Public URLs (optional — marketing/back-links) ─────────────────────
NEXT_PUBLIC_MARKETING_URL=https://klovered-page.vercel.app
NEXT_PUBLIC_SITE_URL=https://klovered-free-nycx.vercel.app
