# Vercel hosts the Next.js frontend ONLY. The Python backend deploys separately
# to Render (see render.yaml); the frontend reaches it at runtime via the
# /api/pipeline/* proxy (PY_API_URL), so its source must not be part of the
# Vercel build. Excluding it also stops Vercel from auto-detecting backend/ as a
# second deployable service and proposing a split monorepo config.
backend/

# Local-only helpers, never part of a deployment.
_concurrency.mjs
_stress.mjs
sample-rfps/
